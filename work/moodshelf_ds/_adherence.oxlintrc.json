{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/reading/**",
              "ui_kits/moodshelf/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Spectral|Hanken Grotesk|Caveat))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Spectral, Hanken Grotesk, Caveat."
      },
      {
        "selector": "JSXOpeningElement[name.name='AuraOrb'] > JSXAttribute > JSXIdentifier[name!=/^(?:colors|size|label|caption|key|ref|className|style|children)$/]",
        "message": "<AuraOrb> doesn't accept that prop. Declared props: colors, size, label, caption."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:reading|finished|want|dnf|favorite)$/]",
        "message": "<Badge> status must be one of 'reading' | 'finished' | 'want' | 'dnf' | 'favorite'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BookCoverPalette'] > JSXAttribute > JSXIdentifier[name!=/^(?:bg|fg|rule|key|ref|className|style|children)$/]",
        "message": "<BookCoverPalette> doesn't accept that prop. Declared props: bg, fg, rule."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|soft|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'soft' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|pad|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, pad, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|raised|sunken|inverse)$/]",
        "message": "<Card> tone must be one of 'paper' | 'raised' | 'sunken' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmotionTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:emotion|color|size|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<EmotionTag> doesn't accept that prop. Declared props: emotion, color, size, onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmotionTag'] > JSXAttribute[name.name='emotion'] > Literal[value!=/^(?:joy|heartbreak|comfort|longing|eerie|tender|wonder|rage)$/]",
        "message": "<EmotionTag> emotion must be one of 'joy' | 'heartbreak' | 'comfort' | 'longing' | 'eerie' | 'tender' | 'wonder' | 'rage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmotionTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<EmotionTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|fill|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:book-open|book|library|bookmark|heart|share|plus|star|sparkles|feather|flame|moon|search|x|settings|user|calendar|check|chevron-right|chevron-left|arrow-right|more-horizontal|quote|bell|camera|download|instagram|pen-line|globe)$/]",
        "message": "<Icon> name must be one of 'book-open' | 'book' | 'library' | 'bookmark' | 'heart' | 'share' | 'plus' | 'star' | 'sparkles' | 'feather' | 'flame' | 'moon' | 'search' | 'x' | 'settings' | 'user' | 'calendar' | 'check' | 'chevron-right' | 'chevron-left' | 'arrow-right' | 'more-horizontal' | 'quote' | 'bell' | 'camera' | 'download' | 'instagram' | 'pen-line' | 'globe'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|variant|size|iconSize|active|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: name, variant, size, iconSize, active, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|soft|solid|glass)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'soft' | 'solid' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, variant, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|search)$/]",
        "message": "<Input> variant must be one of 'default' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShelfBook'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|author|src|palette|key|ref|className|style|children)$/]",
        "message": "<ShelfBook> doesn't accept that prop. Declared props: title, author, src, palette."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
